# Purpose: extract all major requested organization families with a root_type column for downstream classification.
# Fields: root_type, root_typeLabel, item, itemLabel, creation_date P571, dissolution_date P576, country P17, located_in P276, parent_organization P749, instance_of P31, industry P452.
# Expected result order: 1e6+ rows on the public Wikidata endpoint.
# License: Wikidata data is CC0.
SELECT DISTINCT ?root_type ?root_typeLabel ?item ?itemLabel ?creation_date ?dissolution_date ?country ?countryLabel ?located_in ?located_inLabel ?parent_organization ?parent_organizationLabel ?instance_of ?instance_ofLabel ?industry ?industryLabel WHERE {
  VALUES ?root_type {
    wd:Q188509 wd:Q4830453 wd:Q783794 wd:Q161726 wd:Q43702 wd:Q41710
    wd:Q11425700 wd:Q43229 wd:Q1530705 wd:Q2143665 wd:Q210980 wd:Q319608
    wd:Q44613 wd:Q15243209 wd:Q4287745
  }
  ?item wdt:P31/wdt:P279* ?root_type.
  OPTIONAL { ?item wdt:P571 ?creation_date. }
  OPTIONAL { ?item wdt:P576 ?dissolution_date. }
  OPTIONAL { ?item wdt:P17 ?country. }
  OPTIONAL { ?item wdt:P276 ?located_in. }
  OPTIONAL { ?item wdt:P749 ?parent_organization. }
  OPTIONAL { ?item wdt:P31 ?instance_of. }
  OPTIONAL { ?item wdt:P452 ?industry. }
  SERVICE wikibase:label { bd:serviceParam wikibase:language "en,ja". }
}
ORDER BY ?root_type ?item
LIMIT 5000
OFFSET 0

